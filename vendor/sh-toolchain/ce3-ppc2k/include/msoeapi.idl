	[
		object,
		uuid(97C09B16-461A-11D1-B3EB-0000F8757A1E),
		helpstring("IOEExtension Interface"),
		pointer_default(unique)
	]


interface IOEExtension : IUnknown
{
	// Initialize -- always first function called. 

	HRESULT Initialize(
		DWORD dwReserved				// currently we don't need any parameters.
	);

	// Get HTML Page: If this member succeeds then it will return the location of an HTML page to use as the 'front page' or BodyBar.
	// This overrides any registry setting.
	HRESULT GetHTMLPage(
		[in]  int	ePage,				// type of HTML page  
		LPSTR	lpszHtmlPage,			// URL location of HTML page
		[in, out] int * cch				// size of lpszHtmlPage
	);

}

cpp_quote("#endif // _MSOEEXT_IIDS__")
