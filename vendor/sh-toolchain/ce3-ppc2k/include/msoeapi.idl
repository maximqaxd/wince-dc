//  Copyright (C) Microsoft Corporation, 1997
//
//  Contents: IOEMenuExtension
//
//  History:    6-Nov-1997         YSt        Created
//
//--------------------------------------------------------------------------

// This file will be processed by the MIDL tool to
// produce the type library (oeext.tlb) and marshalling code.

cpp_quote("#ifndef _MSOEEXT_IIDS__")
cpp_quote("#define _MSOEEXT_IIDS__")

	
	[
		object,
		uuid(97C09B13-461A-11D1-B3EB-0000F8757A1E),
		helpstring("IOEMenuExtension Interface"),
		pointer_default(unique)
	]

	interface IOEMenuExtension : IUnknown
	{
       // called by OE to pre-assign a block of ID commands that an extension is allowed to use, commands added to the menu
       // that fall in this range will be delegated to this extension
	   // We call this function when we switch view and release object when we leave view.
		HRESULT InitMenuExt(
				[in] const DWORD dwView,		
				[in] const ULONG uCmdMin,
				[in] const ULONG uCmdMax
				);

        // This is for appending to the Tools menu. For now uMenuId will always be OEMENU_TOOLS to allow appending to the bottom of
        // the tools menu. We will pass in the hMenu of the tools menu and the extension can append menu in it's predefined range
		HRESULT AppendMenu(
			[in] const ULONG uMenuId,
			[in] const HMENU hMenu, 
			DWORD dwReserved
			);
 
         // This allows an extension to insert their own top-level menu. We will only allow one to be inserted. We will preallocate a menuID and
         // pass it in uMenuId - this can be used to identify the custom menu in OnInitMenuPopup. Extension passed name of toplevel menu
         // back, renamed do confusion with  Win32 InsertMenu
		HRESULT AddTopLevelMenu(
			[in] const HMENU hMenu, 
			[in] const ULONG uMenuId, 
			LPSTR lpszMenuText, 
			ULONG cchMax, 
			DWORD dwReserved
			);
 
		// execute Cmd 
		HRESULT Execute(
			[in] const HWND hwndParent, 
			[in] const ULONG uCmd, 
			DWORD dwReserved);
        
        // uMenuId is either OE-allocated ID from InsertMenu, or constant from OEMENU_*
		HRESULT OnInitMenuPopup(
			[in] const HMENU hMenuPopup, 
			[in] const ULONG uMenuId, 
			DWORD dwReserved);

        // called when hovering over a menuID to get statusbar text
		HRESULT GetStatusText(
			[in] const ULONG uCmd, 
			LPSTR lpsz, 
			ULONG cchMax);

	};
	

cpp_quote("enum tagOEMenu")
cpp_quote("{")
cpp_quote("   	OEMENU_TOOLS = 6,")
cpp_quote("};")
cpp_quote("")
