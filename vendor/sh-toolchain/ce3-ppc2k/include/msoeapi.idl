// HENUMSTORE
//--------------------------------------------------------------------------
DECLARE_HANDLE(HENUMSTORE);
typedef HENUMSTORE *LPHENUMSTORE;

//+-------------------------------------------------------------------------
//
//  Copyright (C) Microsoft Corporation, 1995 - 1995.
//
//  Contents: IOutlookExpress
//
//  History:    11-Oct-1997         SteveBailey         Created
