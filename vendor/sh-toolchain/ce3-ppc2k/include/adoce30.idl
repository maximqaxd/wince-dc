	[
		object,
		uuid(113033F3-F682-11D2-BB62-00C04F680ACC),
		dual,
		helpstring("ADOCE Collection"),
		pointer_default(unique)
	]
	interface _Collection : IDispatch
	{
		[propget, id(1)] HRESULT Count([out, retval] long *pVal);
		[restricted, id(DISPID_NEWENUM)] HRESULT _NewEnum([out, retval] IUnknown **ppvObject);
		[id(0x60020002)] HRESULT Refresh(void);
		[hidden, propget] HRESULT Element(VARIANT *pvar, int index);
	};


	[
		object,
		uuid(113033F4-F682-11D2-BB62-00C04F680ACC),
