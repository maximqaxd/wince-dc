		[propget, id(8)] HRESULT NumericScale([out, retval] short *pVal);
		[propget, id(0)] HRESULT Value([out, retval] VARIANT *pVal);
		[propput, id(0)] HRESULT Value([in] VARIANT newVal);
	};


