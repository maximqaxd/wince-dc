	[
		object,
		uuid(113033F6-F682-11D2-BB62-00C04F680ACC),
		dual,
		helpstring("ADOCE Recordset"),
		pointer_default(unique)
	]
	interface _Recordset : IDispatch
	{
		[id(1)] HRESULT AddNew([in, optional] VARIANT FieldList,
							   [in, optional] VARIANT Values);
		[id(2)] HRESULT CancelUpdate(void);
		[id(3)] HRESULT Clone([in, optional, defaultvalue(adLockUnspecified)] LockTypeEnum LockType, 
								[retval, out]  _Recordset **ppvObject);
		[id(4)] HRESULT Close(void);
		[id(5)] HRESULT Delete([in, defaultvalue(1)] long AffectRecords);
		[id(6)] HRESULT GetRows([in, defaultvalue(adGetRowsRest)] long Rows, 
								[in, optional] VARIANT Start, 
								[in, optional] VARIANT Fields, 
								[retval, out] VARIANT *pvar);
		[id(7)] HRESULT Move([in] long NumRecords, 
							 [in, optional] VARIANT Start);
		[id(8)] HRESULT MoveFirst(void);
		[id(9)] HRESULT MoveLast(void);
		[id(10)] HRESULT MoveNext(void);
		[id(11)] HRESULT MovePrevious(void);
		[id(12)] HRESULT Open([in, optional] VARIANT Source, 
							  [in, optional] VARIANT ActiveConnection, 
							  [in, defaultvalue(adOpenUnspecified)] CursorTypeEnum CursorType, 
							  [in, defaultvalue(adLockUnspecified)] LockTypeEnum LockType, 
							  [in, defaultvalue(-1 /* adCmdUnspecified */)] long Options);
		[id(13)] HRESULT Requery(void);
		[id(14)] HRESULT Supports([in] CursorOptionEnum CursorOptions, 
								  [retval, out] VARIANT_BOOL *pb);
		[id(15)] HRESULT Update([in, optional] VARIANT Fields, 
								[in, optional] VARIANT Values);

		[propget, id(16)] HRESULT AbsolutePage([out, retval] long *pVal);
		[propput, id(16)] HRESULT AbsolutePage([in] long newVal);
		[propget, id(17)] HRESULT AbsolutePosition([out, retval] long *pVal);
		[propput, id(17)] HRESULT AbsolutePosition([in] long newVal);
		[propget, id(18)] HRESULT BOF([out, retval] VARIANT_BOOL *pVal);
		[propget, id(19)] HRESULT Bookmark([out, retval] VARIANT *pVal);
		[propput, id(19)] HRESULT Bookmark([in] VARIANT newVal);
		[propget, id(20)] HRESULT CacheSize([out, retval] long *pVal);
		[propput, id(20)] HRESULT CacheSize([in] long newVal);
		[propget, id(21)] HRESULT CursorType([out, retval] CursorTypeEnum *pVal);
		[propput, id(21)] HRESULT CursorType([in] CursorTypeEnum newVal);
		[propget, id(22)] HRESULT EditMode([out, retval] EditModeEnum *pVal);
		[propget, id(23)] HRESULT EOF([out, retval] VARIANT_BOOL *pVal);
		[propget, id(0)]  HRESULT Fields([out, retval] Fields** pvObject); 
		[propget, id(24)] HRESULT LockType([out, retval] LockTypeEnum *pVal);
		[propput, id(24)] HRESULT LockType([in] LockTypeEnum newVal);
		[propget, id(25)] HRESULT PageCount([out, retval] long *pVal);
		[propget, id(26)] HRESULT PageSize([out, retval] long *pVal);
		[propput, id(26)] HRESULT PageSize([in] long newVal);
		[propget, id(27)] HRESULT RecordCount([out, retval] long *pVal);
		[propget, id(28)] HRESULT Source([out, retval] BSTR *pVal);
		[propput, id(28)] HRESULT Source([in] BSTR newVal);
		[propputref, id(29)] HRESULT ActiveConnection([in] VARIANT newVal);
		[propget, id(29)] HRESULT ActiveConnection([out, retval] VARIANT * pConn);
		[propput, id(29)] HRESULT ActiveConnection([in] VARIANT newVal);
		[propget, id(30)] HRESULT ErrorDescription([out, retval] BSTR *pVal);

		[id(31)] HRESULT Find([in] BSTR Criteria, 
							[in, optional, defaultvalue(0)] long SkipRecords,
							[in, optional, defaultvalue(adSearchForward)] SearchDirectionEnum SearchDirection,
							[in, optional] VARIANT Start);

		[id(32)] HRESULT Seek(	[in] VARIANT KeyValues,
								[in, optional, defaultvalue(adSeekFirstEQ)] SeekEnum SeekOption);


		[propget, id(33)] HRESULT Index([out, retval] BSTR* pbstrIndex);
		[propput, id(33)] HRESULT Index([in] BSTR pbstrIndex);
		[propget, id(35)] HRESULT Filter([out, retval] VARIANT* Criteria);
		[propput, id(35)] HRESULT Filter([in] VARIANT Criteria);
		[propget, id(36)]
		HRESULT _stdcall Properties([out, retval] Properties ** ppProperties);
		[propget, id(37)]
		HRESULT _stdcall State([out, retval] long* plObjState);
	};

	[
