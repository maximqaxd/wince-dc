# Minimal SH-4 C runtime (replaces the absent fulllibc.lib). File names match the
# fulllibc PDB objects. crtfp.c = soft-float stubs (no fulllibc original).
TARGETNAME=crt
TARGETTYPE=LIBRARY
WINCECPU=1
SOURCES= \
    memmove.c memset.c memcmp.c strcmp.c strlen.c \
    __divlu.c __modlu.c __modls.c i64div.c i64mod.c \
    lshi64.c rshui64.c crtfp.c
